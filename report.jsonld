        }
      ],
      "vocDefinition": [
        {
          "@language": "en",
          "@value": "The power to form or join a governing body for a certain period of time. A mandate may represent one or more seats."
        },
        {
          "@language": "nl",
          "@value": "De bevoegdheid om gedurende een bepaalde periode een bestuursorgaan te vormen of er deel van uit te maken. Een mandaat kan één of meerdere zetels voorstellen."
        }
      ],
      "scope": "https://data.vlaanderen.be/id/concept/scope/InPackage",
      "parent": [
